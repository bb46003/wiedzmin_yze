<section class="sheet-header">
  <div class="image-container">
    {{#if (not tokenDisplay)}}
    <img
      class="profile-img"
      src="{{@root.actor.img}}"
      data-edit="img"
      data-action="editImage"
      data-edit="img"
    />
    {{else}}
    <img
      class="profile-img"
      src="{{@root.tokenImg}}"
      data-action="editImage"
      data-edit="prototypeToken.texture.src"
    />
    {{/if}}
      <div class="toggle-wrapper">
  <span class="label">Obraz</span>
  <label class="switch">
    <input type="checkbox" data-action="toggle" {{#if tokenDisplay}}checked{{/if}}>
    <span class="slider"></span>
  </label>

  <span class="label">Token</span>
</div>
  </div>

  <div class="identity-npc">
    <div class="flexrow">
      <label>Nazwa</label>
      <input
        name="name"
        type="text"
        value="{{actor.name}}"
        placeholder="Name"
      />
    </div>

    <div class="flexrow">
      <a data-action="inicjatywa">{{systemFields.inicjatywa.label}}</a>
      {{formInput
        systemFields.inicjatywa
        value=system.inicjatywa
        type="number"
      }}
    </div>
    <div class="flexrow podwojne">
      <div class="flexcol staty">
        <label>{{systemFields.punkty_mocy.fields.value.label}}</label>
        {{formInput
          systemFields.punkty_mocy.fields.value
          value=system.punkty_mocy.value
          type="number"
        }}
      </div>
      <p>/</p>
      <div class="flexcol staty">
        <label>{{systemFields.punkty_mocy.fields.max.label}}</label>
        {{formInput
          systemFields.punkty_mocy.fields.max
          value=system.punkty_mocy.max
          type="number"
        }}
      </div>
    </div>
    <div class="flexrow podwojne">
      <div class="flexcol staty">
        <label>{{systemFields.zycie.fields.value.label}}</label>
        {{formInput
          systemFields.zycie.fields.value
          value=system.zycie.value
          type="number"
        }}
      </div>
      <p>/</p>
      <div class="flexcol staty">
        <label>{{systemFields.zycie.fields.max.label}}</label>
        {{formInput
          systemFields.zycie.fields.max
          value=system.zycie.max
          type="number"
        }}
      </div>
    </div>
    <div class="flexrow">
      <a data-action="rzut" data-type="obrona">{{systemFields.obrona.label}}</a>
      {{formInput systemFields.obrona value=system.obrona type="number"}}
    </div>
    <div class="flexrow">
      <label>{{systemFields.wielkosc.label}}</label>
      {{formInput systemFields.wielkosc value=system.wielkosc}}
    </div>
    <div class="flexrow">
      <label>{{systemFields.szybkosc.fields.podstawa.label}}</label>
      {{formInput
        systemFields.szybkosc.fields.podstawa
        value=system.szybkosc.podstawa
        type="number"
      }}
    </div>
    <div class="flexrow">
      {{#if (ne system.tabela_atakow "")}}
        <a data-action="atakZTabeli">{{systemFields.tabela_atakow.label}}</a>
      {{else}}
        <label>{{systemFields.tabela_atakow.label}}</label>
      {{/if}}
      {{formInput systemFields.tabela_atakow value=system.tabela_atakow}}
    </div>
  </div>
</section>
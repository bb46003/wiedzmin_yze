<div class="wiedzmin-roll-chat">
  <h4>
    {{#if (not forsowac)}}
      Forsowany wynik rzutu na
    {{else}}
      Wynik rzutu na
    {{/if}}
    {{atrubutLabel}}
    {{umiejkaLabel}}</h4>

  {{#if item}}
    <span>Wykorzytując Talenty
      {{#each item}}
        <button
          class="openTalenet"
          data-itemID="{{this.uuid}}"
        >{{this.name}}</button>
      {{/each}}
    </span>
  {{/if}}
  <div class="result-summary">

    {{#if isSuccess}}
      <h4><strong>Sukces!</strong></h4>
      {{#if extraSuccesses}}
        <p>Nadprogramowe sukcesy: {{extraSuccesses}}</p>
      {{/if}}

    {{else}}
      <p><strong>Porażka</strong></p>
    {{/if}}

    {{#if pech}}
      <p class="pech-warning">
        ⚠ Pech! (Na kościach adrenaliny wypadła 1)
      </p>
    {{/if}}

    {{#if iloscPrzerzuconych}}
      <p>Przerzucono:
        {{iloscPrzerzuconych}}
        Zwykłych kości i
        {{adrenalinaDice.rolls.length}}d6 Kości Adrenaliny</p>
    {{/if}}
  </div>

  <div class="dice-roll" data-action="expandRoll">

    <div class="dice-formula">{{formula}}</div>

     {{> "systems/wiedzmin_yze/templates/chat/wiedzmin-kosci.hbs"}}

  </div>
  {{#if (and forsowac (not pech))}}
    <div class="forsowanie">
      <button class="forsuj-button" data-action="forsuj">Forsuj</button>
    </div>
  {{/if}}

</div>
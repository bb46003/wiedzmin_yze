<div class="wiedzmin-roll-chat">
  <h4>
      Wynik rzutu na Czar
    <br />{{czar}}
    z
    <br />{{atrubutLabel}}
    <br />{{umiejkaLabel}}</h4>
  {{#if item}}
    <span>Wykorzytując Talenty
      {{#each item}}
        <button
          class="openTalenet"
          data-itemID="{{this.uuid}}"
        >{{this.name}}</button>
      {{/each}}
    </span>
  {{/if}}
  {{#if obrazeniaDlaRzucajacego}}
    <div>
        <label>Zurzyto więcej Punktów Mocy niż posiadano, co spododowało zadanie {{iloscObrazen}} obrażeń.</label>
    </div>
  {{/if}}
  <div class="result-summary">

    {{#if isSuccess}}
      <h4><strong>Sukces!</strong></h4>
      {{#if extraSuccesses}}
        <p>Nadprogramowe sukcesy: {{extraSuccesses}}</p>
      {{/if}}

    {{else}}
      <p><strong>Porażka</strong></p>
    {{/if}}

    {{#if pech}}
      <p class="pech-warning">
        ⚠ Pech! (Na kościach adrenaliny wypadła 1)
      </p>
    {{/if}}

    {{#if iloscPrzerzuconych}}
      <p>Przerzucono:
        {{iloscPrzerzuconych}}
        Zwykłych kości i
        {{adrenalinaDice.rolls.length}}d6 Kości Adrenaliny</p>
    {{/if}}
  </div>

  <div class="dice-roll" data-action="expandRoll">

    <div class="dice-formula">{{formula}}</div>

    <div class="dice-tooltip">
      <div class="wrapper">

        {{#if normalDice}}
          <section class="tooltip-part">
            <div class="dice">
              <header class="part-header flexrow">
                <span class="part-formula">

                  Zwykłe Kosci
                  {{normalDice.rolls.length}}d6
                </span>
              </header>

              <ol class="dice-rolls">
                {{#each normalDice.rolls}}
                  <li class="roll die d6 {{classes}}">
                    {{result}}
                  </li>
                {{/each}}
              </ol>
            </div>
          </section>
        {{/if}}

        {{#if adrenalinaDice}}
          <section class="tooltip-part">
            <div class="dice">
              <header class="part-header flexrow">
                <span class="part-formula">
                  Kości Adrenaliny
                  {{adrenalinaDice.rolls.length}}d6
                </span>
              </header>

              <ol class="dice-rolls">
                {{#each adrenalinaDice.rolls}}
                  <li class="roll die d6 {{classes}}">
                    {{result}}
                  </li>
                {{/each}}
              </ol>
            </div>
          </section>
        {{/if}}

      </div>
    </div>

  </div>
  <div>
    {{#if cel}}
      <p>Cel: </p>
      <div class="target-info">
        {{#each cel}}
          <div class="target-token" data-targetID="{{this.id}}">
            <image src="{{this.img}}" width="50" height="50" />
            <p>{{this.name}}</p>
            {{#if (eq czar.system.obrona.typ "brak")}}

            {{else}}
            {{#if (eq czar.system.obrona.typ "unik")}}
            <button class="unik" data-targetID="{{this.id}}">
              <img class="unik-icon" src="systems\wiedzmin_yze\assets\jump.png" data-tooltip="Unik"></img>
            </button>
            {{else}}
            <p>Cel wykonuje test na 
                {{#if (eq czar.system.obrona.typ "inny")}} 
                {{czar.system.obrona.inny}}
                {{else}}
                {{czar.system.obrona.typ}}
                {{/if}}
                </p>
            {{/if}}
            <p> Z Modyfikatorem {{czar.system.obrona.modyfikator}}</p>        
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}
  </div>
  {{#if (ne czar.system.cel.typ "pojedynczy")}}
  <div class="obszar">
    <button class="stworz-template" data-action="stworzTemplate">
        <p>Stwórz {{czar.system.cel.typ}} o wielkości {{czar.system.cel.wartosc}} m</p>
    </button>
  </div>
  {{/if}}
  {{#if czar.system.obrazenia.zadajeObrazenia}}
  <div class="obrazenia">
    <button class="zadaj-obrazenia" data-action="zadajObrazenia">
      {{#if cel}}Zadaj obrażenia Celom
      {{else}}Zadaj obrażenia{{/if}}
    </button>
  </div>
  {{/if}}
</div>
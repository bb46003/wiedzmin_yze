<section>
  <div class="rasa" data-item-id="{{item.id}}">
    <header class="rasa-header flexrow">
      <div class="image-container">
        <img
          class="profile-img"
          src="{{item.img}}"
          data-edit="img"
          data-action="editImage"
          data-edit="img"
        />
      </div>
      <h3>Nazwa Rasy
        <input
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="Name"
        />
      </h3>
    </header>
    <div class="rasa-body">
      <div class="form-group enriched">
        <label>Opis</label>
        {{formInput
          opis.field
          value=opis.value
          enriched=opis.enriched
          toggled="true"
        }}
      </div>
      <div class="form-group">
        <label>
          Zapewnia Bonus do Atrybutów?
          {{formInput
            systemFields.zapewniaBonudDoAtrybutu
            value=system.zapewniaBonudDoAtrybutu
          }}
        </label>
        <label>
          Pozwala Wybrać Atrybuty grającemu?
          {{formInput
            systemFields.wybieraneAtrybuty
            value=system.wybieraneAtrybuty
          }}
        </label>
        <label>
          Ogranicza wybrane atrybuty?
          {{formInput
            systemFields.ograniczaAtrybut
            value=system.ograniczaAtrybut
          }}

        </label>
      </div>
      {{#if system.zapewniaBonudDoAtrybutu}}
        <div class="opcje">

          <label>Powiązany Atrybut
            <button data-action="dodajAtrybut"><i
                class="fa fa-plus"
              ></i></button></label>
        </div>

        {{#each system.bonusyAtrybuty as |bonus index|}}

          <div class="bonusy">
            <div class="form-group">
              <label>Atrybut
                <button data-action="usunAtrybut" data-id="{{index}}"><i
                    class="fa fa-minus"
                  ></i></button></label>
              {{formInput
                @root.systemFields.bonusyAtrybuty.element.fields.atrybut
                name=(concat "system.bonusyAtrybuty." index ".atrybut")
                value=bonus.atrybut
              }}
            </div>

            <div class="form-group">
              <label>Wartość Bonusu</label>
              {{formInput
                @root.systemFields.bonusyAtrybuty.element.fields.bonus
                name=(concat "system.bonusyAtrybuty." index ".bonus")
                value=bonus.bonus
              }}
            </div>

          </div>
        {{/each}}
      {{/if}}
      {{#if system.wybieraneAtrybuty}}
        <div class="form-group">
          <label>Ilość Atrybutów do wybrania</label>
          {{formInput
            systemFields.iloscWybieranychAtrybutuow
            value=system.iloscWybieranychAtrybutuow
          }}
        </div>
        <div class="form-group">
          <label>Bonus do Atrybutów</label>
          {{formInput
            systemFields.bonusDoWybranych
            value=system.bonusDoWybranych
          }}
        </div>
      {{/if}}
      {{#if system.ograniczaAtrybut}}
      <div class="form-group">
        <label> Wybierz ograniczone Atrybuty i podaj wartosc max</label>
                           <button data-action="dodajOgraniczenie"><i
                class="fa fa-plus"
              ></i></button></label>
          {{#each system.ograniczonyAtrybut as |art index|}}
         <div class="bonusy">
            <div class="form-group">
              <label>Atrybut
                <button data-action="usunAtrybut" data-id="{{index}}"><i
                    class="fa fa-minus"
                  ></i></button></label>
              {{formInput
                @root.systemFields.ograniczonyAtrybut.element.fields.atrybut
                name=(concat "system.ograniczonyAtrybut." index ".atrybut")
                value=art.atrybut
              }}
            </div>

            <div class="form-group">
              <label>Wartość Maksymalna</label>
              {{formInput
                @root.systemFields.ograniczonyAtrybut.element.fields.wartoscMax
                name=(concat "system.ograniczonyAtrybut." index ".wartoscMax")
                value=art.wartoscMax
              }}
            </div>

          </div>
          {{/each}}
      </div>
      {{/if}}
      <div class="form-group">
        <label>
          Zapewnia Bonus do Umiejętności?
          {{formInput
            systemFields.zapewniaBonusDoUmiejki
            value=system.zapewniaBonusDoUmiejki
          }}
        </label>
        <label>
          Wybierane Umiejętności nie powiązane z Profesją?
          {{formInput
            systemFields.wybieraneUmiejki
            value=system.wybieraneUmiejki
          }}
        </label>
      </div>
      {{#if system.zapewniaBonusDoUmiejki }}
        <div class="opcje">
          <label>Powiązane Umiejętności
            <button data-action="dodajUmiejki"><i
                class="fa fa-plus"
              ></i></button></label>
        </div>
        {{#each system.bonusyUmiejki as |bonus index|}}
          <div class="bonusy">
            <div class="form-group">
              <label>Umiejętności
                <button data-action="usunUmiejki" data-id="{{index}}"><i
                    class="fa fa-minus"
                  ></i></button></label>
              {{formInput
                @root.systemFields.bonusyUmiejki.element.fields.umiejka
                name=(concat "system.bonusyUmiejki." index ".umiejka")
                value=bonus.umiejka
              }}
            </div>

            <div class="form-group">
              <label>Wartość Bonusu</label>
              {{formInput
                @root.systemFields.bonusyUmiejki.element.fields.bonus
                name=(concat "system.bonusyUmiejki." index ".bonus")
                value=bonus.bonus
              }}
            </div>

          </div>
        {{/each}}
      {{/if}}
      {{#if system.wybieraneUmiejki}}
        <label>Ile umiejętności do Wybrania?</label>
        {{formInput
          systemFields.iloscUmiejekDoWyboru
          value=system.iloscUmiejekDoWyboru
        }}
                    <div class="form-group">
              <label>Wartość Bonusu</label>
              {{formInput
                @root.systemFields.bonusyUmiejki.element.fields.bonus
                name= "system.bonusyUmiejki.0.bonus"
                value=system.bonusyUmiejki.0.bonus
              }}
            </div>
      {{/if}}
      <div class="talent-rasowy">
        <label>Talenty Rasowe</label>
        {{#if (eq talenty.length 0)}}
          <label>Przeciągnij i upuść Talent dla tej rasy.<br />
            Przygotuj go jako normalny Talent z wartością PD 0.
          </label>
        {{else}}
          {{#each talenty}}
            <div class="rasowe-talenty">
              <button
                class="powiazanyTalent"
                data-id="{{this.id}}"
                data-action="otworzTalent"
              >{{this.name}}</button>

              <button data-action="usunTalent" data-id="{{this.id}}"><i
                  class="fa fa-trash"
                ></i></button>

            </div>

          {{/each}}
        {{/if}}
      </div>
    </div>
  </div>
</section>
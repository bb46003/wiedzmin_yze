<section class="talents-section">
  <div class="talent-card" data-item-id="{{item.id}}">

    <header class="talent-header flexrow">
      <div class="image-container">
        <img
          class="profile-img"
          src="{{item.img}}"
          data-edit="img"
          data-action="editImage"
          data-edit="img"
        />
      </div>
      <h3>Nazwa Pancerza
        <input
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="Name"
        />
      </h3>

    </header>
    <div class="bron-glowna">
      <div class="form-group">
        <label>efekt</label>
        {{formInput systemFields.efekt value=system.efekt}}
      </div>
      <div class="form-group">
        <label>Wartość Efektu</label>
        {{formInput
          systemFields.wartosc_efektu
          value=system.wartosc_efektu
          type="number"
        }}
      </div>
      <div class="form-group">
        <label>Wartość</label>
        {{formInput systemFields.wartosc value=system.wartosc}}
      </div>
        <div class="form-group">
        <label>Wyparowanie</label>
        {{formInput systemFields.wyparowanie value=system.wyparowanie}}
      </div>

    </div>
    <div class="profesja-body">
      <div class="form-group enriched">
        <label>Opis</label>
        {{formInput
          opis.field
          value=opis.value
          enriched=opis.enriched
          toggled="true"
        }}
      </div>
    </div>
  </div>
</section>
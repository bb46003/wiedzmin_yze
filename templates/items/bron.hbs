<section class="talents-section">
  <div class="talent-card" data-item-id="{{item.id}}">

    <header class="talent-header flexrow">
      <div class="image-container">
        <img
          class="profile-img"
          src="{{item.img}}"
          data-edit="img"
          data-action="editImage"
          data-edit="img"
        />
      </div>
      <h3>Nazwa Broni
        <input
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="Name"
        />
      </h3>

    </header>
    <div class="bron-glowna">
      <div class="form-group">
        <label>Celność</label>
        {{formInput systemFields.celnosc value=system.celnosc type="number"}}
      </div>
      <div class="form-group">
        <label>Obrażenia</label>
        {{formInput
          systemFields.obrazenia
          value=system.obrazenia
          type="number"
        }}
      </div>
      <div class="form-group">
        <label>Wartość</label>
        {{formInput systemFields.wartosc value=system.wartosc}}
      </div>
      <div class="form-group">
        <label>Wymaga Amunicji?</label>
        {{formInput systemFields.wymagaAmunicji value=system.wymagaAmunicji}}
      </div>
      {{#if system.wymagaAmunicji}}
        <div class="form-group">
          <label>Zapas Amunicji</label>
          {{formInput systemFields.zapasAmunicji value=system.zapasAmunicji}}
        </div>
      {{/if}}
    </div>
    <div class="profesja-body">
      <div class="form-group enriched">
        <label>Opis</label>
        {{formInput
          opis.field
          value=opis.value
          enriched=opis.enriched
          toggled="true"
        }}
      </div>
    </div>
  </div>
</section>
<section class="sheet-header">
  <div class="image-container">
    <img
      class="profile-img"
      src="{{actor.img}}"
      data-edit="img"
      data-action="editImage"
      data-edit="img"
    />
  </div>
  <div class="identity">
    <label>Miano</label>
    <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
    <label>Rasa</label>
    {{#if rasa}}
      <div class="flexrow">
        <label class="rasa-label"> {{rasa.rasaName}}</label>
        <a
          class="threeDots"
          data-action="itemContextMenu"
          data-item="{{rasa.id}}"
        >
          <i class="fas fa-ellipsis-v"></i>
        </a>
      </div>
    {{else}}
      <div></div>
    {{/if}}
    <label>Profesja</label>
    {{#if profesja}}
      <div class="flexrow">
        <label class="rasa-label"> {{profesja.profesjaName}}</label>
        <a
          class="threeDots"
          data-action="itemContextMenu"
          data-item="{{profesja.id}}"
        >
          <i class="fas fa-ellipsis-v"></i>
        </a>
      </div>
    {{else}}
      <div></div>
    {{/if}}

    <label>PD</label>
    {{formInput systemFields.pd value=system.pd type="number"}}
    <label>Zamożność</label>
    {{formInput systemFields.zamoznosc value=system.zamoznosc type="number"}}
    <label>Cele Osobiste</label>
    <textarea name="system.cele_osobiste" rows="4">
      {{system.cele_osobiste}}
    </textarea>
  

  </div>
</section>
<section class="all-attribues">
  {{#each systemFields.atrybuty as |atrybut|}}
    <div class="attribute-group">
      <div class="attribute-main">
        <a data-action="rzut_atrybut" data-atrybut="{{atrybut.name}}">{{localize
            atrybut.fields.value.label
          }}</a>
          <div class="flexrow atr-um">
        {{formInput
          atrybut.fields.value
          value=(lookup (lookup @root.system.atrybuty atrybut.name) "value")
          type="number"
        }}
        <span>/{{atrybut.fields.value.max}}</span>
        </div>
      </div>

      {{#with
        (lookup (lookup @root.system.atrybuty atrybut.name) "umiejetnosci")
        as |skills|
      }}
        <div class="attribute-subskills">
          {{#each atrybut.fields.umiejetnosci as |umiejka|}}
            <div class="skill">
              <a
                data-action="rzut_umiejka"
                data-umiejka="{{umiejka.name}}"
                data-atrybut="{{atrybut.name}}"
                {{#if (zawodowa umiejka.name @root.umiejkiZawodowe)}}
                  class="zawodowa"
                {{/if}}
                {{#if (eq umiejka.name "fach")}}
                 {{#if (zawodowa @root.system.specjalizacjaFach @root.umiejkiZawodowe)}}
                  class="zawodowa"
                {{/if}}
                {{/if}}

              >{{localize umiejka.label}}
                {{#if (eq umiejka.name "fach")}}
                
                  {{formInput
                    @root.systemFields.specjalizacjaFach
                    value=@root.system.specjalizacjaFach
                  }}
                  
                {{/if}}
              </a>
              <div class="flexrow atr-um">
              {{formInput
                umiejka
                value=(lookup skills umiejka.name)
                type="number"
              }}
                  <span>/{{umiejka.max}}</span>
              </div>
            </div>
          {{/each}}
        </div>
      {{/with}}
    </div>
  {{/each}}
</section>